# Activate pixi environment
watch_file pixi.toml
watch_file pixi.lock
eval "$(pixi shell-hook)"

# Use Homebrew Ruby 3.3 on macOS (keg-only, not in PATH by default)
if [[ "$(uname)" == "Darwin" ]] && [[ -d "/opt/homebrew/opt/ruby@3.3/bin" ]]; then
  path_add PATH "/opt/homebrew/opt/ruby@3.3/bin"
  path_add PATH "/opt/homebrew/lib/ruby/gems/3.3.0/bin"
fi

# Linux-specific library paths
if [[ "$(uname)" == "Linux" ]]; then
  path_add LD_LIBRARY_PATH "${CONDA_PREFIX}/lib"
  path_add LD_LIBRARY_PATH "/lib/x86_64-linux-gnu"
fi
